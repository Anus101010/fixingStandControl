-- Auto Sprint (Xenon V3) + Infinite Dash. Меню: вкл/выкл + ползунки Power 60, Delay 0.6.

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local Debris = game:GetService("Debris")
local CoreGui = game:GetService("CoreGui")
local player = Players.LocalPlayer

local state = { AutoSprint = true, InfiniteDash = true }
local settings = { DashPower = 60, DashDelay = 0.6 }

local Create
do
    local I
    if type(_G) == "table" and _G.Instance then
        I = _G.Instance
    elseif game and getmetatable then
        local mt = getmetatable(game)
        if mt and mt.__index then I = mt.__index end
    end
    if type(I) == "table" and type(I.new) == "function" then
        Create = function(className, parent) return I.new(className, parent) end
    elseif type(I) == "function" then
        Create = function(className, parent) return I(className, parent) end
    end
end

-- Auto Sprint (Xenon V3)
task.spawn(function()
    while true do
        task.wait()
        if not state.AutoSprint then continue end
        local c = player.Character
        if not c then continue end
        local rf = c:FindFirstChild("RemoteFunction")
        if not rf then continue end
        pcall(function()
            local r = rf:InvokeServer("ReturnSprint")
            if r and r.IsSprinting ~= true then
                rf:InvokeServer("ToggleSprinting")
            end
        end)
    end
end)

-- Infinite Dash (Xenon V3)
local lastDash = 0
local dashFolder
if Create then
    local ok, folder = pcall(function() return Create("Folder", workspace) end)
    if ok and folder then
        dashFolder = folder
    else
        Create = nil
    end
end

local function getStroke()
    local dir, anim = 180, "6926086304"
    if UIS:IsKeyDown(Enum.KeyCode.A) then dir, anim = 90, "6926086567"
    elseif UIS:IsKeyDown(Enum.KeyCode.D) then dir, anim = -90, "6926086883"
    elseif UIS:IsKeyDown(Enum.KeyCode.W) then dir, anim = 0, "6926086032"
    end
    return dir, anim
end

UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not state.InfiniteDash or not Create or not dashFolder then return end
    local c = player.Character
    if not c then return end
    local dk = player:FindFirstChild("PlayerStats") and player.PlayerStats:FindFirstChild("DashKey")
    if not dk then return end
    if input.KeyCode ~= Enum.KeyCode[dk.Value] then return end
    if tick() - lastDash < settings.DashDelay then return end

    local hum = c:FindFirstChildWhichIsA("Humanoid")
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    lastDash = tick()
    local dir, animId = getStroke()
    local power = settings.DashPower
    pcall(function()
        local anim = Create("Animation", dashFolder)
        anim.AnimationId = "rbxassetid://" .. animId
        hum:LoadAnimation(anim):Play()
        local bv = Create("BodyVelocity", hrp)
        bv.Velocity = (hrp.CFrame * CFrame.Angles(0, math.rad(dir), 0)).LookVector * power
        bv.MaxForce = Vector3.new(55555, 1000, 55555)
        Debris:AddItem(bv, 0.25)
    end)
end)

-- Меню (как в Xenon V3: тогглы + ползунки Dash Power, Dash Delay). Если меню нет — L/O вкл/выкл.
if not Create then
    UIS.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.L then state.AutoSprint = not state.AutoSprint
        elseif input.KeyCode == Enum.KeyCode.O then state.InfiniteDash = not state.InfiniteDash
        end
    end)
    return
end

local menuGui = Create("ScreenGui", CoreGui)
menuGui.Name = "MatchaStandMenu"
menuGui.ResetOnSpawn = false

local frame = Create("Frame", menuGui)
frame.Size = UDim2.new(0, 200, 0, 180)
frame.Position = UDim2.new(0, 20, 0, 100)
frame.BackgroundColor3 = Color3.fromRGB(28, 28, 32)
frame.BorderSizePixel = 0
local corner = Create("UICorner", frame)
corner.CornerRadius = UDim.new(0, 8)

local title = Create("TextLabel", frame)
title.Size = UDim2.new(1, -10, 0, 28)
title.Position = UDim2.new(0, 8, 0, 4)
title.BackgroundTransparency = 1
title.Text = "Fixing Stand"
title.TextColor3 = Color3.fromRGB(220, 220, 220)
title.TextSize = 14
title.Font = Enum.Font.Gotham
title.TextXAlignment = Enum.TextXAlignment.Left

local lblSprint, lblDash

local function makeToggle(y, text, getState, callback)
    local btn = Create("TextButton", frame)
    btn.Size = UDim2.new(1, -16, 0, 26)
    btn.Position = UDim2.new(0, 8, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    btn.BorderSizePixel = 0
    btn.Text = ""
    btn.AutoButtonColor = true
    Create("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local lbl = Create("TextLabel", btn)
    lbl.Size = UDim2.new(1, 0, 1, 0)
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(240, 240, 240)
    lbl.TextSize = 12
    lbl.Font = Enum.Font.Gotham
    lbl.Text = text
    btn.MouseButton1Click:Connect(function()
        callback()
        lbl.Text = text:gsub(": .*", ": " .. (getState() and "ON" or "OFF"))
    end)
    return btn, lbl
end

local function makeSlider(y, name, minVal, maxVal, getVal, setVal, precise)
    local height = 36
    local container = Create("Frame", frame)
    container.Size = UDim2.new(1, -16, 0, height)
    container.Position = UDim2.new(0, 8, 0, y)
    container.BackgroundTransparency = 1

    local nameLbl = Create("TextLabel", container)
    nameLbl.Size = UDim2.new(1, -50, 0, 18)
    nameLbl.Position = UDim2.new(0, 0, 0, 0)
    nameLbl.BackgroundTransparency = 1
    nameLbl.Text = name
    nameLbl.TextColor3 = Color3.fromRGB(200, 200, 200)
    nameLbl.TextSize = 11
    nameLbl.Font = Enum.Font.Gotham
    nameLbl.TextXAlignment = Enum.TextXAlignment.Left

    local valueLbl = Create("TextLabel", container)
    valueLbl.Size = UDim2.new(0, 44, 0, 18)
    valueLbl.Position = UDim2.new(1, -44, 0, 0)
    valueLbl.BackgroundTransparency = 1
    valueLbl.Text = tostring(getVal())
    valueLbl.TextColor3 = Color3.fromRGB(180, 180, 180)
    valueLbl.TextSize = 11
    valueLbl.Font = Enum.Font.Gotham
    valueLbl.TextXAlignment = Enum.TextXAlignment.Right

    local track = Create("Frame", container)
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 20)
    track.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    track.BorderSizePixel = 0
    Create("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Create("Frame", track)
    fill.Size = UDim2.new((getVal() - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.Position = UDim2.new(0, 0, 0, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 120, 160)
    fill.BorderSizePixel = 0
    Create("UICorner", fill).CornerRadius = UDim.new(1, 0)

    local function updateVal(scale01)
        local val = minVal + (maxVal - minVal) * math.clamp(scale01, 0, 1)
        if precise then
            val = math.floor(val * 10 + 0.5) / 10
        else
            val = math.floor(val + 0.5)
        end
        val = math.clamp(val, minVal, maxVal)
        setVal(val)
        fill.Size = UDim2.new((val - minVal) / (maxVal - minVal), 0, 1, 0)
        valueLbl.Text = tostring(val)
    end

    local dragging
    track.InputBegan:Connect(function(input)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        dragging = true
        local x = input.Position.X - track.AbsolutePosition.X
        updateVal(x / math.max(track.AbsoluteSize.X, 1))
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UIS.InputChanged:Connect(function(input)
        if not dragging or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local x = input.Position.X - track.AbsolutePosition.X
        updateVal(x / math.max(track.AbsoluteSize.X, 1))
    end)

    return container
end

local function updateToggleLabels()
    if lblSprint then lblSprint.Text = "Auto Sprint: " .. (state.AutoSprint and "ON" or "OFF") end
    if lblDash then lblDash.Text = "Infinite Dash: " .. (state.InfiniteDash and "ON" or "OFF") end
end

_, lblSprint = makeToggle(36, "Auto Sprint: ON", function() return state.AutoSprint end, function()
    state.AutoSprint = not state.AutoSprint
    updateToggleLabels()
end)
_, lblDash = makeToggle(66, "Infinite Dash: ON", function() return state.InfiniteDash end, function()
    state.InfiniteDash = not state.InfiniteDash
    updateToggleLabels()
end)
updateToggleLabels()

makeSlider(96, "Dash Power", 10, 200, function() return settings.DashPower end, function(v)
    settings.DashPower = v
end, false)

makeSlider(136, "Dash Delay", 0, 3.5, function() return settings.DashDelay end, function(v)
    settings.DashDelay = v
end, true)

-- Перетаскивание за заголовок
local dragging, dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UIS.InputChanged:Connect(function(input)
    if not dragging or input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
    local delta = input.Position - dragStart
    frame.Position = UDim2.new(0, startPos.X.Offset + delta.X, 0, startPos.Y.Offset + delta.Y)
end)

-- End — скрыть/показать меню
UIS.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.End then
        menuGui.Enabled = not menuGui.Enabled
    end
end)
